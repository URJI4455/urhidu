{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["*.html", "*.css", "script.js", "*.png", "*.jpg", "*.json"]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/index.js"
    }
  ]
}
